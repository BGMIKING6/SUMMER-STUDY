<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Summer Study</title>
<style>
*{
margin:0;
padding:0;
box-sizing:border-box;
font-family:Arial, sans-serif;
}

body{
background:#f4f6ff;
color:#111;
}

header{
background:#dcd6f7;
padding:20px;
text-align:center;
font-size:32px;
font-weight:bold;
}

nav{
background:#b8b2e6;
padding:12px;
text-align:center;
}

nav a{
color:black;
text-decoration:none;
margin:10px;
font-weight:bold;
}

.container{
padding:30px;
text-align:center;
}

.grid{
display:grid;
grid-template-columns:repeat(auto-fit,minmax(220px,1fr));
gap:20px;
margin-top:30px;
}

.card{
padding:30px;
border-radius:20px;
font-size:22px;
font-weight:bold;
cursor:pointer;
transition:0.3s;
color:black;
}

.card:hover{
transform:scale(1.05);
}

.class9{background:#6ea8fe;}
.class10{background:#66d9e8;}
.class11{background:#9775fa;}
.class12{background:#ff6bcb;}

.stream{
background:#51cf66;
}

.subject{
background:#ffd43b;
}

footer{
margin-top:50px;
padding:20px;
text-align:center;
background:#dcd6f7;
}

.hidden{
display:none;
}

button{
padding:12px 20px;
border:none;
border-radius:10px;
background:#444;
color:white;
cursor:pointer;
margin-top:20px;
}
</style>
</head>
<body>

<header>SUMMER STUDY</header>

<nav>
<a href="#" onclick="showPage('home')">Home</a>
<a href="#" onclick="showPage('classes')">Classes</a>
<a href="#" onclick="showPage('coding')">Coding</a>
</nav>

<div class="container">

<!-- HOME -->
<div id="home">
<h1>Welcome to Summer Study</h1>
<p>CBSE Notes, Subjects, Coding Tutorials</p>
</div>

<!-- CLASSES -->
<div id="classes" class="hidden">
<h2>Select Class</h2>
<div class="grid">
<div class="card class9" onclick="openClass(9)">Class 9</div>
<div class="card class10" onclick="openClass(10)">Class 10</div>
<div class="card class11" onclick="openClass(11)">Class 11</div>
<div class="card class12" onclick="openClass(12)">Class 12</div>
</div>
</div>

<!-- SUBJECT AREA -->
<div id="subjects" class="hidden"></div>

<!-- CODING -->
<div id="coding" class="hidden">
<h2>Programming Languages</h2>
<div class="grid">
<div class="card subject">HTML</div>
<div class="card subject">CSS</div>
<div class="card subject">JavaScript</div>
<div class="card subject">Python</div>
<div class="card subject">Java</div>
</div>
</div>

</div>

<footer>
Founder - Anish
</footer>

<script>
function showPage(id){
document.getElementById("home").classList.add("hidden");
document.getElementById("classes").classList.add("hidden");
document.getElementById("coding").classList.add("hidden");
document.getElementById("subjects").classList.add("hidden");

document.getElementById(id).classList.remove("hidden");
}

function openClass(cls){
let box=document.getElementById("subjects");
box.classList.remove("hidden");

if(cls==9 || cls==10){
box.innerHTML=`
<h2>Class ${cls} Subjects</h2>
<div class="grid">
<div class="card subject">Maths</div>
<div class="card subject">Science</div>
<div class="card subject">English</div>
<div class="card subject">Social Science</div>
<div class="card subject">Computer</div>
</div>
<button onclick="showPage('classes')">Back</button>
`;
}

if(cls==11 || cls==12){
box.innerHTML=`
<h2>Class ${cls} Streams</h2>
<div class="grid">
<div class="card stream" onclick="openStream(${cls},'Science')">Science</div>
<div class="card stream" onclick="openStream(${cls},'Commerce')">Commerce</div>
<div class="card stream" onclick="openStream(${cls},'Humanities')">Humanities</div>
</div>
<button onclick="showPage('classes')">Back</button>
`;
}
}

function openStream(cls,stream){
let box=document.getElementById("subjects");

let data="";

if(stream=="Science"){
data=`
Physics, Chemistry, Maths, English, Computer Science
`;
}

if(stream=="Commerce"){
data=`
Accountancy, Business Studies, Economics, English, Maths
`;
}

if(stream=="Humanities"){
data=`
History, Geography, Political Science, English, Sociology
`;
}

let subjects=data.split(",");

let html=`<h2>Class ${cls} - ${stream}</h2><div class="grid">`;

subjects.forEach(sub=>{
html+=`<div class="card subject">${sub}</div>`;
});

html+=`</div><button onclick="openClass(${cls})">Back</button>`;

box.innerHTML=html;
}

showPage('home');
</script>

</body>
</html>
